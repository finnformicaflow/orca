# Copy to `.env` (gitignored, auto-loaded by Bun). Per-machine config only.

# REQUIRED. Base dir holding the repos listed in orca.config.ts — their paths resolve against it,
# so the config needs no editing on a new laptop. The bridge fails loudly at startup if unset.
ORCA_DEV_ROOT=$HOME/Documents/dev

# REQUIRED for Slack notify/bump. User token (xoxp…) — posts the message VERBATIM from your identity
# via chat.postMessage, deterministic and instant, the one path for every provider. Without it a send
# fails with a clear error (and copies the message to your clipboard so you can paste it manually).
# SLACK_TOKEN=xoxp-...

# Optional overrides:
# ORCA_STATE_DIR=$HOME/.orca   # lease + ledger dir (kept out of every worktree)
# ORCA_API_PORT=8787           # local bridge port
# ORCA_UI_PORT=8788            # Vite dev UI port
